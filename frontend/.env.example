# ============================================================
# Frontend SGOHA · Variables de entorno (plantilla)
# ------------------------------------------------------------
# 1. Copia este archivo: cp .env.example .env
# 2. Ajusta los valores a tu entorno local.
# 3. NUNCA subas .env al repositorio (está en .gitignore).
#
# Nota: en Vite TODAS las variables expuestas al cliente deben
# empezar con el prefijo VITE_ para ser inyectadas en bundle.
# ============================================================

# ----- API del backend SGOHA -----
# URL base del API (incluye el sufijo /api).
VITE_API_URL=http://localhost:5001/api

# Si el backend corre en producción detrás de un dominio:
# VITE_API_URL=https://api.sgoha.midominio.edu/api
