# ============================================================
# Backend SGOHA · Variables de entorno (plantilla)
# ------------------------------------------------------------
# 1. Copia este archivo: cp .env.example .env
# 2. Ajusta los valores a tu entorno local.
# 3. NUNCA subas .env al repositorio (está en .gitignore).
# ============================================================

# ----- Servidor -----
# Puerto del API. En macOS el 5000 puede estar ocupado por AirPlay,
# por eso usamos 5001 por defecto.
PORT=5001

# Entorno de ejecución: development | test | production
NODE_ENV=development

# URL del frontend (usado por CORS y para enlaces en correos).
CLIENT_URL=http://localhost:5173

# ----- Base de datos (MongoDB) -----
# Mongo local sin auth:
MONGO_URI=mongodb://127.0.0.1:27017/HorariosAcademicos
# Mongo local con auth (ej. contenedor Docker "mongo-local"):
# MONGO_URI=mongodb://dev:dev@127.0.0.1:27017/HorariosAcademicos?authSource=admin
# MongoDB Atlas:
# MONGO_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.xxxx.mongodb.net/HorariosAcademicos?retryWrites=true&w=majority

# Nombre de la base (opcional si ya viene en MONGO_URI).
MONGO_DB_NAME=HorariosAcademicos

# ----- Autenticación (JWT) -----
# Genera un secreto fuerte en producción (mín. 32 chars aleatorios).
# Ejemplo: openssl rand -hex 32
JWT_SECRET=change_this_secret_in_production
# Límite de peticiones (seguridad OWASP)
LOGIN_RATE_LIMIT_MAX=20
API_RATE_LIMIT_MAX=300
JSON_BODY_LIMIT=1mb
